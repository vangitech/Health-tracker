# Server
PORT=5001
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
JWT_SECRET=<your-random-secret>
FRONTEND_URL=http://localhost:5174
BACKEND_URL=http://localhost:5001

# Resend - for email verification codes
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# Cloudinary - for image uploads
# Get these from https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# OAuth - Google (required for Google Sign-In)
# Get these from https://console.cloud.google.com/apis/credentials
# Auth.js callback URL: http://localhost:5001/api/authjs/callback/google
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# OAuth - Apple (optional)
# Get these from https://developer.apple.com/account/resources/
# Auth.js callback URL: http://localhost:5001/api/authjs/callback/apple
# clientSecret is a JWT generated from your Apple private key: https://bal.so/apple-gen-secret
APPLE_CLIENT_ID=com.example.serviceid
APPLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OAuth - Microsoft (optional)
# Register app at https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
# Auth.js callback URL: http://localhost:5001/api/authjs/callback/microsoft-entra-id
MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MICROSOFT_TENANT_ID=common

# OAuth - Yahoo (optional)
# Get these from https://developer.yahoo.com/apps/
YAHOO_CLIENT_ID=dj0yJmk9xxxxxxxxxxxxxxxxxxxxx-xxxxxxxxx
YAHOO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
